@@ -161,5 +162,11 @@ def get_zmq_rpc_path_lmcache(
         f"{base_url}/engine_{engine_id}_service_{service_name}_"
         f"lmcache_rpc_port_{rpc_port}"
     )
+    ipc_path_max_len = getattr(zmq, "IPC_PATH_MAX_LEN", 107)
